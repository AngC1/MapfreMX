#!/bin/sh
# Maven Wrapper script

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-"$(cd "$(dirname "$0")" && pwd)"}"

if [ -n "$MAVEN_PROJECTBASEDIR" ]; then
  MAVEN_PROJECTBASEDIR=$(cd "$MAVEN_PROJECTBASEDIR" && pwd)
fi

# Resolve the wrapper jar
WRAPPER_DIR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
WRAPPER_JAR="$WRAPPER_DIR/maven-wrapper.jar"

if [ ! -f "$WRAPPER_JAR" ]; then
  echo "Maven Wrapper jar not found at $WRAPPER_JAR" >&2
  echo "Please download it or run mvnw.cmd on Windows to auto-download." >&2
  exit 1
fi

JAVA_CMD=${JAVA_HOME:+"$JAVA_HOME/bin/java"}
if [ -z "$JAVA_CMD" ]; then
  JAVA_CMD=java
fi

MAVEN_WRAPPER_PROPERTIES="$WRAPPER_DIR/maven-wrapper.properties"

exec "$JAVA_CMD" \
  -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" \
  -classpath "$WRAPPER_JAR" \
  org.apache.maven.wrapper.MavenWrapperMain \
  -Dmaven.home="$MAVEN_PROJECTBASEDIR/.mvn/wrapper" \
  -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" \
  -Dwrapper.properties="$MAVEN_WRAPPER_PROPERTIES" \
  "$@"
